{
  "name": "emmanuel-ai-trade",
  "version": "1.0.0",
  "description": "Professional trading signals app",
  "private": true,
  "workspaces": ["backend", "mobile", "web"],
  "scripts": {
    "setup": "npm install && npm run setup:backend && npm run setup:mobile && npm run setup:web",
    "setup:backend": "cd backend && npm install",
    "setup:mobile": "cd mobile && npm install",
    "setup:web": "cd web && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:mobile": "cd mobile && npm start",
    "dev:web": "cd web && npm run dev",
    "build:backend": "cd backend && npm run build",
    "build:mobile": "cd mobile && npm run build",
    "build:web": "cd web && npm run build"
  }
}
